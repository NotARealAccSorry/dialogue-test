 active page\nfunction displayCurrentPage () {\n    // If a text sprite already exists, clean it up before making a new one\n    if (myTextSprite) {\n        myTextSprite.destroy()\n    }\n    pageText = dialoguePages[currentPageIndex]\n    // Create text sprite (Width: 140, Height: 20)\n    myTextSprite = fancyText.create(pageText, 140, 0, fancyText.tiny_4)\n    fancyText.setLineHeight(myTextSprite, 5)\n    // Perfectly centers it in your 160x120 canvas dialogue window\n    myTextSprite.setPosition(80, 107)\n    stateTransitions.changeState(\"Dialogue\")\n    fancyText.animateAtSpeed(myTextSprite, fancyText.TextSpeed.Slow, fancyText.AnimationPlayMode.InBackground)\n}\n// --- Core Functions ---\n// 1. Call this to start a conversation\nfunction startDialogue (fullText: string) {\n    // Slice text into chunks of 50 chars\n    dialoguePages = splitTextIntoPages(fullText, 50)\n    currentPageIndex = 0\n    displayCurrentPage()\n}\n// Player presses B to advance or close dialogue\nstateTransitions.onButtonEvent(\"Dialogue\", stateTransitions.Player.One, stateTransitions.Button.B, ControllerButtonEvent.Pressed, function () {\n    // Optional: If text is still animating, you could cancel it to instantly show text first\n    // fancyText.cancelAnimation(myTextSprite)\n    currentPageIndex += 1\n    // If there are more pages, show the next one\n    if (currentPageIndex < dialoguePages.length) {\n        displayCurrentPage()\n    } else {\n        // No more pages left! Clean up and exit state\n        if (myTextSprite) {\n            myTextSprite.destroy()\n        }\n        stateTransitions.changeState(\"DialogueEnd\")\n    }\n})\n// --- Event Handlers ---\n// Draw the box UI when entering dialogue state\nstateTransitions.onStateEvent(stateTransitions.TransitionEvent.Enter, \"Dialogue\", function () {\n    scene.backgroundImage().drawRect(0, 95, 160, 25, 2)\n    scene.backgroundImage().fillRect(1, 96, 158, 23, 3)\n})\nlet currentPageIndex = 0\nlet dialoguePages: string[] = []\nlet pageText = \"\"\nlet myTextSprite: fancyText.TextSprite = null\nlet words: string[] = []\nlet currentPage = \"\"\n// --- Test Run ---\n// Give it a massive string to see it automatically split across pages\nstartDialogue(\"This is a test of a much longer dialogue system that will automatically split up into multiple clean pages so nothing breaks or spills over the borders. us ususussusussu sus su sus sus sus suuusu ss sus su sus sus sus   uss  us susususussu suu uuu u uu  u u \")\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":2,"length1":34,"diffs":[[1,"    \"name\": \"text help\",\n"]]}]}]},{"timestamp":1781903385713,"editorVersion":"4.0.14","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":9640,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable type=\"KIND_SpriteKind\" id=\"(XLJF4f/A+6=bNr+fLY[\">Player</variable><variable type=\"KIND_SpriteKind\" id=\"]d~EoD.Q(/-P!~nkggC9\">Projectile</variable><variable type=\"KIND_SpriteKind\" id=\"Jr4D|.Tr%7_BoR^3@C}l\">Food</variable><variable type=\"KIND_SpriteKind\" id=\"t0:%^%RZ!_?p_gn=K9xz\">Enemy</variable><variable id=\"}DS11?PJV:]_h3XPV.25\">Lunarcycle</variable><variable id=\"nOcZVZkwCPSXktNUah5e\">mySprite</variable><variable id=\"I(7r?}0/$rNYkmTBpZ(o\">Useless Img</variable><variable id=\"`,EVLZ;r`s%^t5+x~pTa\">myTextSprite</variable><variable id=\"|@t/O,03f5YUkw--/GgH\">picture</variable><variable id=\"=H^g$K:y_sP:9-Q0{:j|\">IsOnText</variable><variable id=\"cZSlO1l`|W3uVkK*)#E)\">Pages</variable><variable id=\"KUR-Y$Cft4`6pt]zI%Y,\">TextChunks</variable><variable id=\"sKEv*hzV?Nf2F%!As9#(\">index</variable><variable id=\"^QdVP)Yx|K#U@tr.~I6]\">list</variable></variables><block type=\"pxt-on-start\" x=\"-530\" y=\"467\"></block><block type=\"function_definition\" x=\"-343\" y=\"558\"><mutation name=\"TextChunker\" functionid=\"2I0/KT~:HiHERe8A`-SB\"><arg name=\"text\" id=\"ba)B2Guom]LdTo=VBNu0\" type=\"string\">